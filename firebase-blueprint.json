{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User specific information and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "GlobalConfig": {
      "title": "Global Config",
      "description": "Global costs and parameters",
      "type": "object",
      "properties": {
        "halfTruckDoubleDropFee": { "type": "number" },
        "defaultAmortizationYears": { "type": "number" },
        "truckCostPerKm": { "type": "number" },
        "palletCostPerKm": { "type": "number" }
      },
      "required": ["halfTruckDoubleDropFee", "defaultAmortizationYears"]
    },
    "businessCase": {
      "title": "Business Case",
      "description": "A business case calculation record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "years": { "type": "number" },
        "logisticsType": { "type": "string" },
        "references": { "type": "array" },
        "geographicService": { "type": "array" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "title"]
    },
    "CatalogProduct": {
      "title": "Catalog Product",
      "description": "Product master data reference",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "family": { "type": "string" },
        "brand": { "type": "string" },
        "format": { "type": "string" },
        "packaging": { "type": "string" },
        "material": { "type": "string" },
        "cost": { "type": "number" }
      },
      "required": ["name", "family", "brand", "cost"]
    },
    "BrandLogistics": {
      "title": "Brand Logistics",
      "description": "Logistics origin for each brand",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "origin": { "type": "string" }
      },
      "required": ["brand", "origin"]
    },
    "ColdEquipment": {
      "title": "Cold Equipment",
      "description": "Refrigeration equipment data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "amortizationYears": { "type": "number" }
      },
      "required": ["name", "price", "amortizationYears"]
    },
    "FixedCost": {
      "title": "Fixed Cost",
      "description": "Business fixed costs (salaries, office, etc)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "monthlyAmount": { "type": "number" }
      },
      "required": ["name", "monthlyAmount"]
    },
    "MaintenanceCost": {
      "title": "Maintenance Cost",
      "description": "Maintenance and cleaning costs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["name", "amount"]
    },
    "CapillaryRule": {
      "title": "Capillary Rule",
      "description": "Distribution cost rule for capillary logistics",
      "type": "object",
      "properties": {
        "family": { "type": "string" },
        "format": { "type": "string" },
        "packaging": { "type": "string" },
        "baseCost": { "type": "number" }
      },
      "required": ["family", "format", "packaging", "baseCost"]
    },
    "CoraTrainingRule": {
      "title": "Cora Training Rule",
      "description": "Rule to train Cora's assistant answers based on specific phrase mappings",
      "type": "object",
      "properties": {
        "phrase": { "type": "string" },
        "response": { "type": "string" }
      },
      "required": ["phrase", "response"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "configs/global": {
      "schema": "GlobalConfig",
      "description": "Shared application costs and settings"
    },
    "businessCases/{caseId}": {
      "schema": "BusinessCase",
      "description": "Business case records"
    },
    "catalogProducts/{productId}": {
      "schema": "CatalogProduct",
      "description": "Master list of products"
    },
    "brandLogistics/{brandId}": {
      "schema": "BrandLogistics",
      "description": "Logistics origin by brand"
    },
    "coldEquipment/{equipId}": {
      "schema": "ColdEquipment",
      "description": "Catalog of cold equipment"
    },
    "fixedCosts/{costId}": {
      "schema": "FixedCost",
      "description": "General fixed costs"
    },
    "maintenanceCosts/{mId}": {
      "schema": "MaintenanceCost",
      "description": "Maintenance costs"
    },
    "capillaryRules/{ruleId}": {
      "schema": "CapillaryRule",
      "description": "Specific capillary cost rules"
    },
    "coraTraining/{ruleId}": {
      "schema": "CoraTrainingRule",
      "description": "Cora voice assistant learning rules"
    }
  }
}
